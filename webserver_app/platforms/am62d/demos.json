{
  "demos": [
    {
      "id": "2dfft",
      "name": "2D FFT Benchmark",
      "description": "128x128 2D FFT computation with output verification using C7x DSP",
      "type": "batch",
      "category": "dsp_offload",
      "executable": "demos/mock_rpmsg_2dfft_example",
      "timeout": 10000,
      "expected_duration": "~2 seconds",
      "output_format": "structured",
      "test_data": {
        "input": "/usr/share/2dfft_test_data/2dfft_input_data.bin",
        "expected": "/usr/share/2dfft_test_data/2dfft_expected_output_data.bin"
      },
      "firmware": "/lib/firmware/fft2d_linux_dsp_offload_example.c75ss0-0.release.strip.out",
      "metrics": ["status", "dsp_load", "cycle_count", "ddr_throughput"],
      "ui": {
        "icon": "calculator",
        "color": "blue",
        "show_logs": true,
        "show_metrics": true,
        "display_pass_fail": true
      }
    },
    {
      "id": "2dfft_nodata",
      "name": "2D FFT Lightweight",
      "description": "Parameter-only 2D FFT demo without data transfer (faster startup)",
      "type": "batch",
      "category": "dsp_offload",
      "executable": "demos/mock_rpmsg_2dfft_nodata_example",
      "timeout": 8000,
      "expected_duration": "~1.5 seconds",
      "output_format": "structured",
      "firmware": "/lib/firmware/fft2d_linux_dsp_offload_example.c75ss0-0.release.strip.out",
      "metrics": ["status", "dsp_load", "cycle_count"],
      "ui": {
        "icon": "calculator",
        "color": "cyan",
        "show_logs": true,
        "show_metrics": true,
        "display_pass_fail": true
      }
    },
    {
      "id": "audio_offload",
      "name": "Audio DSP Offload",
      "description": "Real-time 8-channel audio processing with FFT-based filtering on C7x DSP",
      "type": "streaming",
      "category": "dsp_offload",
      "executable": "demos/mock_rpmsg_audio_offload_example",
      "config_file": "/etc/dsp_offload.cfg",
      "sample_audio": "/usr/share/audio_sample/sample_audio.wav",
      "firmware": "/lib/firmware/dsp_audio_filter_offload.c75ss0-0.release.strip.out",
      "ports": {
        "log": 8888,
        "cmd": 8889,
        "in_data": 8890,
        "out_data": 8891
      },
      "metrics": ["frame_count", "latency_ms", "cpu_load", "dsp_load", "amplitude", "filter_state", "exec_mode"],
      "controls": {
        "filter_enable": "SET FFT FILTER",
        "mode_switch": "SET EXEC MODE",
        "uart_interface": "SET HOST INTERFACE"
      },
      "ui": {
        "icon": "volume-up",
        "color": "green",
        "real_time": true,
        "charts": ["latency", "cpu_load", "dsp_load"],
        "show_controls": true,
        "show_network_interface": true
      }
    },
    {
      "id": "audio_control",
      "name": "Audio Control Demo",
      "description": "DSP parameter control demonstration without audio streaming",
      "type": "streaming",
      "category": "dsp_offload",
      "executable": "demos/rpmsg_audio_control_example",
      "config_file": "/etc/dsp_offload.cfg",
      "firmware": "/lib/firmware/dsp_audio_filter_offload.c75ss0-0.release.strip.out",
      "metrics": ["frame_count", "latency_ms", "cpu_load", "dsp_load", "control_params"],
      "controls": {
        "param_control": "SET PARAM",
        "mode_switch": "SET EXEC MODE"
      },
      "ui": {
        "icon": "sliders",
        "color": "orange",
        "real_time": true,
        "charts": ["latency", "cpu_load", "dsp_load"],
        "show_controls": true
      }
    }
  ]
}